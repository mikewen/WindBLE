<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.WindBLE" parent="Theme.MaterialComponents.DayNight.DarkActionBar">
        <!-- Primary brand colors. -->
        <item name="colorPrimary">@color/bg_card</item>
        <item name="colorPrimaryVariant">@color/bg_dark</item>
        <item name="colorOnPrimary">@color/text_primary</item>

        <!-- Secondary brand colors. -->
        <item name="colorSecondary">@color/color_accent</item>
        <item name="colorOnSecondary">@color/white</item>

        <!-- UI Colors -->
        <item name="android:windowBackground">@color/bg_dark</item>
        <item name="android:statusBarColor">@color/bg_card</item>
        <item name="android:navigationBarColor">@color/bg_dark</item>

        <!-- Text colors - Ensure readability on dark background -->
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
        <item name="android:textColorPrimaryInverse">@color/black</item>

        <!-- Preference screen styling -->
        <item name="preferenceTheme">@style/PreferenceThemeOverlay</item>
    </style>

    <!-- Data label: small uppercase caption -->
    <style name="LabelText">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textSize">9sp</item>
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:textAllCaps">true</item>
        <item name="android:letterSpacing">0.08</item>
        <item name="android:fontFamily">sans-serif-condensed</item>
    </style>

    <!-- Data value: monospace bold number -->
    <style name="ValueText">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textSize">15sp</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textStyle">bold</item>
        <item name="android:fontFamily">monospace</item>
        <item name="android:text">--</item>
    </style>


    <style name="Theme.WindBLE.Fullscreen" parent="Theme.WindBLE">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
        <item name="android:windowFullscreen">true</item>
    </style>

</resources>
